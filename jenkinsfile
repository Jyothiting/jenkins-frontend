pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/your-repo/frontend.git'
            }
        }

        stage('Deploy to Nginx') {
            steps {
                sh '''
                sudo rm -rf /var/www/html/*
                sudo cp *.html /var/www/html/ || true
                sudo cp *.css /var/www/html/ || true
                sudo cp *.js /var/www/html/ || true
                '''
            }
        }

    }
}
